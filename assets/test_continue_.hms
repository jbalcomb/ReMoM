# test_continue_save.hms
#
# Drives the Main Screen after `--continue` lands us on the newly created test
# game-save.  Names the home city, patrols the starting unit, and saves the
# game to slot 1 with a timestamped name.
#
# Usage:
#   ReMoMber --continue --scenario test_continue_save.hms
#   HeMoM    --continue --scenario test_continue_save.hms
#
# Notes:
#   - The save slot name field rejects underscore.  Using `-` instead.
#   - The backspace loop clears whatever name is in the slot (max 19 chars).
#   - Coordinates are game-space (320x200).

# === Home city naming popup (fires immediately on Continue, turn 0) ===
wait 500ms
backspace                 # clear the random pre-filled city name in one stroke
key C
key l
key a
key u
key d
key e
key s
key v
key i
key l
key l
key e
enter                     # confirm the name; popup closes

wait 500ms
