
# test_continue_save.hms
#
# Drives the Main Screen after `--continue` lands us on the newly created test
# game-save.  Names the home city, patrols the starting unit, then delegates
# to scenario_tail_save_and_quit.hms for the standard save-and-exit sequence.
#
# Usage:
#   ReMoMber --continue --scenario test_continue_save.hms
#   HeMoM    --continue --scenario test_continue_save.hms --dump-save SAVE1.GAM
#
# Notes:
#   - The save slot name comes from the $SAVE_NAME built-in (expanded to
#     "AHP-YYYYMMDDHHMM" by HeMoM_Player at scenario-load time).
#   - Coordinates are game-space (320x200).

# === Home city naming popup (fires immediately on Continue, turn 0) ===
wait 500ms                # let the popup finish loading
backspace                 # clear the random pre-filled city name in one stroke
type Claudesville
enter                     # confirm the name; popup closes

wait 500ms                # let the popup close and the Main Screen settle

# === Main Screen: patrol the active unit stack ===
click 290 180             # Patrol button (rect ~280,176 - 313,186)
wait 300ms                # let the patrol action take effect

# === Save the game and quit (shared tail) ===
include scenario_tail_save_and_quit.hms
